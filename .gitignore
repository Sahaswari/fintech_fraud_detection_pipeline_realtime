# ===================================
# Fraud Detection Pipeline - .gitignore
# ===================================

# ============ Python ============
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
venv/
env/
ENV/
.venv/
virtualenv/

# Distribution / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# Unit test / coverage
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb

# IPython
profile_default/
ipython_config.py

# ============ IDE / Editors ============
# VSCode
.vscode/
*.code-workspace

# PyCharm
.idea/
*.iml
*.iws
.idea_modules/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
.\#*

# ============ MacOS ============
.DS_Store
.AppleDouble
.LSOverride
._*

# ============ Windows ============
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ============ Linux ============
*~
.directory
.Trash-*

# ============ Docker ============
# Don't ignore docker-compose.yml - we need it!
# But ignore runtime files
docker-compose.override.yml

# ============ Kafka ============
# Kafka data directories (if running locally without Docker)
kafka-logs/
zookeeper-data/
/tmp/kafka-*
/tmp/zookeeper/

# ============ Spark ============
# Spark temporary files
spark-warehouse/
metastore_db/
derby.log

# Spark checkpoints and logs
/tmp/checkpoint/
checkpoint/
*.log

# Spark event logs
spark-events/

# ============ Airflow ============
# Airflow runtime files
airflow/logs/*
!airflow/logs/.gitkeep
airflow/*.db
airflow/*.pid
airflow/airflow-webserver.pid
airflow/airflow.cfg
airflow/webserver_config.py
airflow/unittests.cfg

# Airflow logs (keep structure, ignore content)
airflow/logs/**/*
!airflow/logs/**/.gitkeep

# ============ PostgreSQL ============
# PostgreSQL data (Docker volume manages this)
postgres_data/
*.sql.backup

# Database dumps (optional - comment out if you want to commit backups)
*.dump
*.sql.gz

# ============ Data Files ============
# Parquet files (they can be large)
*.parquet
data/batch_output/*.parquet

# CSV exports (optional - keep if needed for submission)
# *.csv

# Large data files
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Keep structure but ignore content
data/**/*
!data/**/.gitkeep

# ============ Reports & Output ============
# Generated reports (optional - you may want to commit final reports)
reports/*.png
reports/*.pdf
reports/*.html
reports/*.txt
reports/*.json

# Keep the reports folder structure
!reports/.gitkeep

# ============ Credentials & Secrets ============
# IMPORTANT: Never commit credentials!
.env
.env.local
.env.*.local
*.pem
*.key
*.crt
credentials.json
secrets.yaml
config.ini

# AWS credentials
.aws/

# ============ Logs ============
# Application logs
*.log
logs/
*.out
*.err

# ============ Temporary Files ============
# Temporary files and caches
tmp/
temp/
*.tmp
*.bak
*.swp
*~.nib

# ============ Java / JVM (for Spark/Kafka) ============
*.class
*.jar
!lib/*.jar  # Keep library JARs if needed
*.war
*.ear
hs_err_pid*

# Maven
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties

# Gradle
.gradle/
build/

# ============ Archive Files ============
# Compressed files (unless needed for submission)
*.zip
*.tar.gz
*.rar
*.7z

# ============ System Files ============
# Thumbnails
*.thumb

# Files that might appear on external disks
.Spotlight-V100
.Trashes

# ============ Project Specific ============
# Downloaded JARs (Spark will download these)
jars/*.jar

# Test data (if you generate large test files)
test_data/
sample_data/

# Benchmark results
benchmarks/
